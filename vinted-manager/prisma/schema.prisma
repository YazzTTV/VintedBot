generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String                @id @default(uuid())
  email     String                @unique
  password  String
  name      String?
  createdAt DateTime              @default(now())
  commandes CommandeFournisseur[]
}

model CommandeFournisseur {
  id                 String           @id @default(uuid())
  userId             String
  numero             String
  fournisseur        Fournisseur
  dateCommande       DateTime
  prixTotal          Decimal          @db.Decimal(10, 2)
  fraisPort          Decimal          @db.Decimal(10, 2)
  nbArticles         Int              @default(1)
  lienProduit        String?
  statut             StatutCommande   @default(COMMANDEE)
  notes              String?
  createdAt          DateTime         @default(now())
  dateArriveeEstimee DateTime?
  articles           Article[]
  user               User             @relation(fields: [userId], references: [id])
  parcels            ParcelTracking[]
}

model Article {
  id                 String              @id @default(uuid())
  commandeId         String
  prixAchatUnitaire  Decimal             @db.Decimal(10, 2)
  fraisPortUnitaires Decimal             @db.Decimal(10, 2)
  lienProduit        String?
  statut             StatutArticle       @default(STOCK)
  dateAjoutStock     DateTime            @default(now())
  notes              String?
  nom                String?
  taille             String?
  commande           CommandeFournisseur @relation(fields: [commandeId], references: [id])
  vente              Vente?
  vintedOrderSynced  VintedOrderSynced?
}

model Vente {
  id                     String          @id @default(uuid())
  articleId              String          @unique
  pseudoAcheteur         String
  prixVente              Decimal         @db.Decimal(10, 2)
  fraisVinted            Decimal         @default(0.70) @db.Decimal(10, 2)
  beneficeNet            Decimal         @db.Decimal(10, 2)
  margePct               Decimal         @db.Decimal(5, 2)
  dateVente              DateTime        @default(now())
  dateLimiteExpedition   DateTime?
  lienVente              String?
  statut                 StatutVente     @default(EN_ATTENTE)
  extensionStatut        ExtensionStatut @default(AUCUNE)
  botAccountId           String?
  parcelId               String?
  purchasePriceSnapshot  Decimal?        @db.Decimal(10, 2)
  shippingCostCalculated Decimal?        @db.Decimal(10, 2)
  spvState               SPVState        @default(A_COMMANDER)
  expedition             Expedition?
  article                Article         @relation(fields: [articleId], references: [id])
  botAccount             BotAccount?     @relation(fields: [botAccountId], references: [id])
  parcel                 ParcelTracking? @relation(fields: [parcelId], references: [id])
  whatsappLogs           WhatsappLog[]
}

model Expedition {
  id              String   @id @default(uuid())
  venteId         String   @unique
  numeroBordereau String?
  dateExpedition  DateTime @default(now())
  transporteur    String?
  notes           String?
  bordereauUrl    String?
  vente           Vente    @relation(fields: [venteId], references: [id])
}

model SourcingProduct {
  id        String   @id @default(uuid())
  account   String
  title     String
  url       String
  fiche     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?

  @@unique([account, url])
}

model BotAccount {
  id               String               @id @default(uuid())
  name             String               @unique
  vintedUsername   String?
  // Colonnes legacy (non utilisées par le code) conservées pour éviter un drop
  // destructif au `prisma db push` : elles contiennent encore des identifiants en base.
  vintedEmail      String?
  vintedPassword   String?
  vintedPhone      String?
  vintedAccountId  String?              @unique
  balancePending   Decimal?             @default(0) @db.Decimal(10, 2)
  balanceAvailable Decimal?             @default(0) @db.Decimal(10, 2)
  lastSync         DateTime?
  accountType      AccountType          @default(TEST)
  vintedEmail      String?
  vintedPhone      String?
  vintedPassword   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  actions          BotActionQueue[]
  logs             ExtensionLog[]
  ventes           Vente[]
  conversations    VintedConversation[]
  metrics          VintedItemMetrics[]
  orders           VintedOrderSynced[]
  winnerQueue      WinnerQueue[]
  fakeListings     FakeListing[]
  rotationLock     RotationLock?
  rotationConfig   RotationConfig?
  rotationEvents   RotationEvent[]
}

model VintedOrderSynced {
  id              String     @id
  botAccountId    String
  title           String
  price           Decimal    @db.Decimal(10, 2)
  itemId          String?
  buyerLogin      String?
  buyerPhoto      String?
  photoUrl        String?
  status          String
  shippingStatus  String?
  trackingCode    String?
  createdAtVinted DateTime
  syncedAt        DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  articleId       String?    @unique
  article         Article?   @relation(fields: [articleId], references: [id])
  botAccount      BotAccount @relation(fields: [botAccountId], references: [id])
}

model VintedConversation {
  id              String          @id
  botAccountId    String
  buyerUsername   String
  buyerPhoto      String?
  title           String?
  itemId          String?
  lastMessage     String?
  lastMessageTime DateTime
  hasOffer        Boolean         @default(false)
  offerPrice      Decimal?        @db.Decimal(10, 2)
  offerStatus     String?
  syncedAt        DateTime        @default(now())
  botAccount      BotAccount      @relation(fields: [botAccountId], references: [id])
  messages        VintedMessage[]
}

model VintedMessage {
  id              String             @id
  conversationId  String
  senderUsername  String
  content         String
  type            String             @default("message") // "message" | "offer" | "status"
  offerPrice      Decimal?           @db.Decimal(10, 2)
  createdAtVinted DateTime
  conversation    VintedConversation @relation(fields: [conversationId], references: [id])
}

model VintedItemMetrics {
  id               String     @id
  botAccountId     String
  title            String
  url              String?
  photoUrl         String?
  viewCount        Int        @default(0)
  favouriteCount   Int        @default(0)
  status           String?
  isWinner         Boolean    @default(false)
  winnerReason     String?
  sourcingUrl      String?
  uploadedAtVinted DateTime
  updatedAt        DateTime   @updatedAt
  price            Decimal?   @db.Decimal(10, 2)
  orderIndex       Int?
  botAccount       BotAccount @relation(fields: [botAccountId], references: [id])
}

// Snapshot complet d'un article ACTIF (photos full-size + attributs), capture par l'extension
// pour permettre le repost APRES vente (Vinted retire les articles vendus de son API).
model ItemSnapshot {
  vintedItemId String   @id
  account      String?
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BotActionQueue {
  id           String     @id @default(uuid())
  botAccountId String
  actionType   String
  payload      Json
  status       String     @default("PENDING")
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  errorMessage String?
  botAccount   BotAccount @relation(fields: [botAccountId], references: [id])
}

model ParcelTracking {
  id                   String               @id @default(uuid())
  trackingNumber       String
  carrier              String?
  carrierCode          String?
  status               ParcelStatus         @default(EN_ATTENTE)
  statusRaw            String?
  lastUpdate           DateTime?
  estimatedDelivery    DateTime?
  lastEventDescription String?
  daysSinceOrder       Int?
  daysInTransit        Int?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  commandeId           String?
  events               ParcelEvent[]
  commande             CommandeFournisseur? @relation(fields: [commandeId], references: [id])
  ventes               Vente[]
}

model ParcelEvent {
  id          String         @id @default(uuid())
  parcelId    String
  date        DateTime
  location    String?
  description String
  status      ParcelStatus   @default(INCONNU)
  stage       String?
  createdAt   DateTime       @default(now())
  parcel      ParcelTracking @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

// Entrée de rotation d'un winner POUR UN COMPTE donné.
// Un même winner sous-jacent (même sourceKey) peut exister sur plusieurs comptes,
// mais jamais deux fois sur le même compte (@@unique). Cycle de vie : QUEUED -> ACTIVE -> (RETIRED).
model WinnerQueue {
  id                String      @id @default(uuid())
  botAccountId      String
  // Identifiant stable du winner sous-jacent (ex: nom de la capture Winner / id sourcing).
  // Partagé entre comptes ; null toléré pour les anciennes lignes.
  sourceKey         String?
  title             String
  sourcingUrl       String?
  originalPhotoUrl  String?
  season            String? // tag saisonnier optionnel (tri auto)
  status            QueueStatus @default(QUEUED)
  // Ordre FIFO recirculant : un invendu swappé à 7j repart en fond de file (max+1).
  queuePosition     Int?
  // Item Vinted live courant (change à chaque repost). Réf. souple vers VintedItemMetrics.id.
  vintedItemId      String?
  publishedAt       DateTime? // 1re mise en ligne du cycle courant (réf. d'âge)
  lastPublishedAt   DateTime? // legacy (conservé, non destructif)
  lastRepostAt      DateTime? // dernier repost (réf. d'âge = max(publishedAt, lastRepostAt))
  unsoldRepostCount Int         @default(0) // compteur N (remis à 0 sur vente)
  soldCount         Int         @default(0) // nb de ventes pour ce compte (preuve de winner)
  retiredAt         DateTime?
  retiredReason     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  botAccount        BotAccount  @relation(fields: [botAccountId], references: [id])

  @@unique([botAccountId, sourceKey])
  @@index([botAccountId, status])
}

// Pool global de fausses annonces (banque d'image), SINGLE-USE GLOBAL :
// une fois assignée à un compte, jamais réutilisée par un autre (clé sourceFolder).
model FakeListing {
  id                String      @id @default(uuid())
  sourceFolder      String      @unique // dossier Produit_XX du Bureau (garantit l'unicité globale)
  photoCount        Int         @default(0)
  status            FakeStatus  @default(AVAILABLE)
  assignedAccountId String?
  language          String? // fr/nl, fixé à l'assignation (génération titre/desc paresseuse)
  title             String?
  description       String?
  vintedItemId      String?
  publishedAt       DateTime?
  lastRepostAt      DateTime?
  unsoldRepostCount Int         @default(0)
  assignedAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  assignedAccount   BotAccount? @relation(fields: [assignedAccountId], references: [id])

  @@index([status])
  @@index([assignedAccountId, status])
}

// VERROU par compte (le « cerveau » passif impose l'exclusion via TTL).
// Tant qu'un verrou non expiré existe, /api/extension/actions retient les REPOST_ITEM du compte
// -> évite la collision Playwright (publication) <-> extension (repost) sur le même onglet Brave.
model RotationLock {
  botAccountId String     @id
  holder       String // ex: "PYTHON_SALVE" | "MANUAL" | "CRON"
  reason       String? // ex: "PUBLISH"
  acquiredAt   DateTime   @default(now())
  expiresAt    DateTime // TTL : auto-libération si le détenteur crashe
  botAccount   BotAccount @relation(fields: [botAccountId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// Paramètres de rotation par compte (valeurs par défaut = décisions validées).
model RotationConfig {
  botAccountId      String     @id
  enabled           Boolean    @default(false) // rollout progressif / dry-run par compte
  targetWinnerSlots Int        @default(35)
  targetFakeSlots   Int        @default(35)
  maxUnsoldReposts  Int        @default(3) // N avant retraite
  repostAgeDays     Int        @default(7)
  dailyWinnerCount  Int        @default(5)
  dailyFakeCount    Int        @default(5)
  updatedAt         DateTime   @updatedAt
  botAccount        BotAccount @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
}

// Journal des décisions de l'ordonnanceur. dryRun=true => calculé mais non exécuté (test Phase 1).
model RotationEvent {
  id           String     @id @default(uuid())
  botAccountId String
  kind         String // "WINNER" | "FAKE"
  refId        String? // WinnerQueue.id ou FakeListing.id
  vintedItemId String?
  // PUBLISH_FRESH | REPOST_SOLD | REPOST_MASKED | REPOST_EXPIRED | SWAP_OUT | RETIRE | FILL_SLOT | SKIP
  decision     String
  reason       String?
  dryRun       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  botAccount   BotAccount @relation(fields: [botAccountId], references: [id])

  @@index([botAccountId, createdAt])
}

model ExtensionLog {
  id           String      @id @default(uuid())
  botAccountId String?
  botName      String
  message      String
  type         String      @default("INFO")
  source       String      @default("EXTENSION")
  createdAt    DateTime    @default(now())
  botAccount   BotAccount? @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
}

model SpyLikedItem {
  id              String    @id @default(uuid())
  itemId          String    @unique
  title           String
  price           Decimal   @db.Decimal(10, 2)
  categoryId      Int
  categoryName    String?
  photoUrl        String?
  url             String?
  brand           String?
  likedAt         DateTime  @default(now())
  soldAt          DateTime?
  removedAt       DateTime?
  status          String    @default("AVAILABLE")
  timeToSellHours Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SpyCategory {
  id         String   @id @default(uuid())
  categoryId Int      @unique
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model WhatsappLog {
  id        String   @id @default(uuid())
  venteId   String?
  message   String
  direction String
  status    String
  createdAt DateTime @default(now())
  vente     Vente?   @relation(fields: [venteId], references: [id])
}

model DmFavoriEvent {
  id            Int      @id @default(autoincrement())
  botName       String
  buyerUsername String
  itemId        String
  originalPrice Float?
  offerPrice    Float?
  status        String   @default("SENT")
  errorMessage  String?
  createdAt     DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  createdAt DateTime @default(now())
}

enum Fournisseur {
  TEMU
  SHEIN
  AUTRE
}

enum StatutCommande {
  COMMANDEE
  EN_TRANSIT
  RECUE
  PANIER
}

enum StatutArticle {
  STOCK
  VENDU
  EXPEDIE
  RELANCE
  EN_TRANSIT
}

enum StatutVente {
  EN_ATTENTE
  EXPEDIEE
  ANNULEE
  A_EXPEDIER
  COMMANDE_A_FAIRE
}

enum ExtensionStatut {
  AUCUNE
  DEMANDEE
  ACCEPTEE
}

enum SPVState {
  A_COMMANDER
  PANIER
  SUIVI_EN_COURS
  ARRIVE_LOGISTICIEN
  TRAITEE
  INCIDENT
  RETOUR
}

enum ParcelStatus {
  EN_ATTENTE
  PRIS_EN_CHARGE
  EN_TRANSIT
  EN_LIVRAISON
  LIVRE
  RETOUR
  INCIDENT
  INCONNU
}

enum AccountType {
  TEST
  VENTE
}

enum QueueStatus {
  QUEUED // en file d'attente (recirculante)
  ACTIVE // en ligne (occupe un des 35 slots)
  RETIRED // sorti du pool (N reposts sans vente / hors saison)
}

enum FakeStatus {
  AVAILABLE // dispo dans la banque, non assignée
  ASSIGNED // assignée à un compte, pas encore publiée
  LIVE // en ligne
  SOLD // vendue
  RETIRED // sortie de rotation
}
