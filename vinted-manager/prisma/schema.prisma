generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String                @id @default(uuid())
  email     String                @unique
  password  String
  name      String?
  createdAt DateTime              @default(now())
  commandes CommandeFournisseur[]
}

model CommandeFournisseur {
  id                 String           @id @default(uuid())
  userId             String
  numero             String
  fournisseur        Fournisseur
  dateCommande       DateTime
  prixTotal          Decimal          @db.Decimal(10, 2)
  fraisPort          Decimal          @db.Decimal(10, 2)
  nbArticles         Int              @default(1)
  lienProduit        String?
  statut             StatutCommande   @default(COMMANDEE)
  notes              String?
  createdAt          DateTime         @default(now())
  dateArriveeEstimee DateTime?
  articles           Article[]
  user               User             @relation(fields: [userId], references: [id])
  parcels            ParcelTracking[]
}

model Article {
  id                 String              @id @default(uuid())
  commandeId         String
  prixAchatUnitaire  Decimal             @db.Decimal(10, 2)
  fraisPortUnitaires Decimal             @db.Decimal(10, 2)
  lienProduit        String?
  statut             StatutArticle       @default(STOCK)
  dateAjoutStock     DateTime            @default(now())
  notes              String?
  nom                String?
  taille             String?
  commande           CommandeFournisseur @relation(fields: [commandeId], references: [id])
  vente              Vente?
  vintedOrderSynced  VintedOrderSynced?
}

model Vente {
  id                     String          @id @default(uuid())
  articleId              String          @unique
  pseudoAcheteur         String
  prixVente              Decimal         @db.Decimal(10, 2)
  fraisVinted            Decimal         @default(0.70) @db.Decimal(10, 2)
  beneficeNet            Decimal         @db.Decimal(10, 2)
  margePct               Decimal         @db.Decimal(5, 2)
  dateVente              DateTime        @default(now())
  dateLimiteExpedition   DateTime?
  lienVente              String?
  statut                 StatutVente     @default(EN_ATTENTE)
  extensionStatut        ExtensionStatut @default(AUCUNE)
  botAccountId           String?
  parcelId               String?
  purchasePriceSnapshot  Decimal?        @db.Decimal(10, 2)
  shippingCostCalculated Decimal?        @db.Decimal(10, 2)
  spvState               SPVState        @default(A_COMMANDER)
  expedition             Expedition?
  article                Article         @relation(fields: [articleId], references: [id])
  botAccount             BotAccount?     @relation(fields: [botAccountId], references: [id])
  parcel                 ParcelTracking? @relation(fields: [parcelId], references: [id])
  whatsappLogs           WhatsappLog[]
}

model Expedition {
  id              String   @id @default(uuid())
  venteId         String   @unique
  numeroBordereau String?
  dateExpedition  DateTime @default(now())
  transporteur    String?
  notes           String?
  bordereauUrl    String?
  vente           Vente    @relation(fields: [venteId], references: [id])
}

model SourcingProduct {
  id        String   @id @default(uuid())
  account   String
  title     String
  url       String
  fiche     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?

  @@unique([account, url])
}

model BotAccount {
  id               String               @id @default(uuid())
  name             String               @unique
  vintedUsername   String?
  vintedAccountId  String?              @unique
  balancePending   Decimal?             @default(0) @db.Decimal(10, 2)
  balanceAvailable Decimal?             @default(0) @db.Decimal(10, 2)
  lastSync         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  actions          BotActionQueue[]
  logs             ExtensionLog[]
  ventes           Vente[]
  conversations    VintedConversation[]
  metrics          VintedItemMetrics[]
  orders           VintedOrderSynced[]
}

model VintedOrderSynced {
  id              String     @id
  botAccountId    String
  title           String
  price           Decimal    @db.Decimal(10, 2)
  itemId          String?
  buyerLogin      String?
  buyerPhoto      String?
  photoUrl        String?
  status          String
  shippingStatus  String?
  trackingCode    String?
  createdAtVinted DateTime
  syncedAt        DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  articleId       String?    @unique
  article         Article?   @relation(fields: [articleId], references: [id])
  botAccount      BotAccount @relation(fields: [botAccountId], references: [id])
}

model VintedConversation {
  id              String          @id
  botAccountId    String
  buyerUsername   String
  buyerPhoto      String?
  title           String?
  itemId          String?
  lastMessage     String?
  lastMessageTime DateTime
  hasOffer        Boolean         @default(false)
  offerPrice      Decimal?        @db.Decimal(10, 2)
  offerStatus     String?
  syncedAt        DateTime        @default(now())
  botAccount      BotAccount      @relation(fields: [botAccountId], references: [id])
  messages        VintedMessage[]
}

model VintedMessage {
  id              String             @id
  conversationId  String
  senderUsername  String
  content         String
  createdAtVinted DateTime
  conversation    VintedConversation @relation(fields: [conversationId], references: [id])
}

model VintedItemMetrics {
  id               String     @id
  botAccountId     String
  title            String
  url              String?
  photoUrl         String?
  viewCount        Int        @default(0)
  favouriteCount   Int        @default(0)
  status           String?
  isWinner         Boolean    @default(false)
  winnerReason     String?
  sourcingUrl      String?
  uploadedAtVinted DateTime
  updatedAt        DateTime   @updatedAt
  price            Decimal?   @db.Decimal(10, 2)
  orderIndex       Int?
  botAccount       BotAccount @relation(fields: [botAccountId], references: [id])
}

model BotActionQueue {
  id           String     @id @default(uuid())
  botAccountId String
  actionType   String
  payload      Json
  status       String     @default("PENDING")
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  errorMessage String?
  botAccount   BotAccount @relation(fields: [botAccountId], references: [id])
}

model ParcelTracking {
  id                   String               @id @default(uuid())
  trackingNumber       String
  carrier              String?
  carrierCode          String?
  status               ParcelStatus         @default(EN_ATTENTE)
  statusRaw            String?
  lastUpdate           DateTime?
  estimatedDelivery    DateTime?
  lastEventDescription String?
  daysSinceOrder       Int?
  daysInTransit        Int?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  commandeId           String?
  events               ParcelEvent[]
  commande             CommandeFournisseur? @relation(fields: [commandeId], references: [id])
  ventes               Vente[]
}

model ParcelEvent {
  id          String         @id @default(uuid())
  parcelId    String
  date        DateTime
  location    String?
  description String
  status      ParcelStatus   @default(INCONNU)
  stage       String?
  createdAt   DateTime       @default(now())
  parcel      ParcelTracking @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

model ExtensionLog {
  id           String      @id @default(uuid())
  botAccountId String?
  botName      String
  message      String
  type         String      @default("INFO")
  source       String      @default("EXTENSION")
  createdAt    DateTime    @default(now())
  botAccount   BotAccount? @relation(fields: [botAccountId], references: [id], onDelete: Cascade)
}

model SpyLikedItem {
  id              String    @id @default(uuid())
  itemId          String    @unique
  title           String
  price           Decimal   @db.Decimal(10, 2)
  categoryId      Int
  categoryName    String?
  photoUrl        String?
  url             String?
  brand           String?
  likedAt         DateTime  @default(now())
  soldAt          DateTime?
  removedAt       DateTime?
  status          String    @default("AVAILABLE")
  timeToSellHours Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SpyCategory {
  id         String   @id @default(uuid())
  categoryId Int      @unique
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model WhatsappLog {
  id        String   @id @default(uuid())
  venteId   String?
  message   String
  direction String
  status    String
  createdAt DateTime @default(now())
  vente     Vente?   @relation(fields: [venteId], references: [id])
}

model DmFavoriEvent {
  id            Int      @id @default(autoincrement())
  botName       String
  buyerUsername String
  itemId        String
  originalPrice Float?
  offerPrice    Float?
  status        String   @default("SENT")
  errorMessage  String?
  createdAt     DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  createdAt DateTime @default(now())
}

enum Fournisseur {
  TEMU
  SHEIN
  AUTRE
}

enum StatutCommande {
  COMMANDEE
  EN_TRANSIT
  RECUE
  PANIER
}

enum StatutArticle {
  STOCK
  VENDU
  EXPEDIE
  RELANCE
  EN_TRANSIT
}

enum StatutVente {
  EN_ATTENTE
  EXPEDIEE
  ANNULEE
  A_EXPEDIER
  COMMANDE_A_FAIRE
}

enum ExtensionStatut {
  AUCUNE
  DEMANDEE
  ACCEPTEE
}

enum SPVState {
  A_COMMANDER
  PANIER
  SUIVI_EN_COURS
  ARRIVE_LOGISTICIEN
  TRAITEE
  INCIDENT
  RETOUR
}

enum ParcelStatus {
  EN_ATTENTE
  PRIS_EN_CHARGE
  EN_TRANSIT
  EN_LIVRAISON
  LIVRE
  RETOUR
  INCIDENT
  INCONNU
}
